# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key - NEVER expose to the browser, server-only
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From the Stripe CLI / Dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET=
# One-time setup fee price ($679), one per plan
STRIPE_PRICE_SETUP_FEE_AFTER_HOURS=
STRIPE_PRICE_SETUP_FEE_247=
# Recurring metered per-minute price for the After Hours plan ($0.42/min)
STRIPE_PRICE_AFTER_HOURS_METERED=
# Recurring metered per-minute price for the 24/7 plan ($0.47/min)
STRIPE_PRICE_247_METERED=

# --- Google OAuth (Calendar + Sheets) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Twilio (assigning existing purchased numbers) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Resend (transactional email) ---
RESEND_API_KEY=
EMAIL_FROM="TruAutomation <notifications@truautomationtechnologies.com>"
LOGAN_NOTIFICATION_EMAIL=info@truautomationtechnologies.com

# --- VAPI ---
# Shared secret VAPI sends back so we can verify the webhook is really from VAPI.
# Set this same value in your VAPI assistant's server webhook config.
VAPI_WEBHOOK_SECRET=
